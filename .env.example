TELEGRAM_TOKEN=
OPENAI_API_KEY=
# Optional model overrides
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_FORMATTER_MODEL=gpt-5.4-mini
OPENAI_SUMMARY_MODEL=gpt-5.4-mini
NOTION_TOKEN=
NOTION_DATABASE_ID=
# Твой Telegram user_id (узнать: написать @userinfobot)
ALLOWED_USER_ID=
# Твой часовой пояс, например Europe/Moscow
TIMEZONE=Europe/Moscow
# Час, с которого начинается новый дневниковый день (0-23), например 4
DIARY_DAY_START_HOUR=0
# Слать сообщения без звука/пуш-уведомлений (true/false)
SILENT_NOTIFICATIONS=true
