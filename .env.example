TELEGRAM_TOKEN=
OPENAI_API_KEY=
# Optional model overrides
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_FORMATTER_MODEL=gpt-5.4-mini
OPENAI_SUMMARY_MODEL=gpt-5.4-mini
# High-reasoning model behind the 🔥 Roast (разъёб) button
OPENAI_ROAST_MODEL=gpt-5.4
NOTION_TOKEN=
NOTION_DATABASE_ID=
# Your Telegram user_id (find it via @userinfobot)
ALLOWED_USER_ID=
# Your timezone, e.g. Europe/Moscow
TIMEZONE=Europe/Moscow
# Hour the diary day starts (0-23), e.g. 4
DIARY_DAY_START_HOUR=0
# Send messages silently, without push notifications (true/false)
SILENT_NOTIFICATIONS=true
# Language the roast (разъёб) replies in, e.g. Russian, English
ROAST_LANGUAGE=Russian
# Optional: override the built-in roast (разъёб) system prompt
ROAST_SYSTEM_PROMPT=
