TELEGRAM_TOKEN=
OPENAI_API_KEY=
# Optional model overrides
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_FORMATTER_MODEL=gpt-5.4-mini
OPENAI_SUMMARY_MODEL=gpt-5.4-mini
NOTION_TOKEN=
NOTION_DATABASE_ID=
# Твой Telegram user_id (узнать: написать @userinfobot)
ALLOWED_USER_ID=
# Твой часовой пояс, например Europe/Moscow
TIMEZONE=Europe/Moscow
# Optional: режим «разъёб» (Anthropic Claude). Без ключа кнопка скрыта.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Optional: переопределение системного промпта «разъёба» (психотерапевта)
ROAST_SYSTEM_PROMPT=
