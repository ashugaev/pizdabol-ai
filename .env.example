TELEGRAM_TOKEN=
OPENAI_API_KEY=
# Optional model overrides
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_FORMATTER_MODEL=gpt-5.4-mini
OPENAI_SUMMARY_MODEL=gpt-5.4-mini
NOTION_TOKEN=
NOTION_DATABASE_ID=
# Your Telegram user_id (find it via @userinfobot)
ALLOWED_USER_ID=
# Your timezone, e.g. Europe/Moscow
TIMEZONE=Europe/Moscow
# Hour the diary day starts (0-23), e.g. 4
DIARY_DAY_START_HOUR=0
# Send messages silently, without push notifications (true/false)
SILENT_NOTIFICATIONS=true
# Optional: roast mode (Anthropic Claude). Without a key the button is hidden.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Language the roast/therapist replies in, e.g. English, Russian
ROAST_LANGUAGE=English
# Optional: override the built-in roast (therapist) system prompt
ROAST_SYSTEM_PROMPT=
